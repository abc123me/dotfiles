#!/usr/bin/env sh

export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'
export EDITOR='nano'

if [ -d "${HOME}/bin" ]; then export PATH="${HOME}/bin:${PATH}"; fi
if [ -d "/sbin" ]; then       export PATH="/sbin:${PATH}"; fi
if [ -d "/usr/sbin" ]; then   export PATH="/usr/sbin:${PATH}"; fi

if [ -f "${HOME}/.config/dotfiles/shell/env" ]; then
    source "${HOME}/.config/dotfiles/shell/env"
fi

[ -d "/opt/bsp/dl" ] && export BR2_DL_DIR="/opt/bsp/dl"
[ -d "/bsp/dl" ]     && export BR2_DL_DIR="/bsp/dl"
